DJANGO_SETTINGS_MODULE=civiscope.settings.dev
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=civiscope
DB_USER=civiscope
DB_PASSWORD=civiscope
DB_HOST=postgres
DB_PORT=5432

# ── API Clients ──────────────────────────────────────────────────────────────
# Token gratuito: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=
PNCP_BASE_URL=https://pncp.gov.br/api/pncp/v1
DADOS_ABERTOS_BASE_URL=https://dados.gov.br/api/3
API_REQUEST_TIMEOUT=30
API_MAX_RETRIES=3
API_RATE_LIMIT_DELAY=0.5
